#!/bin/sh

# Pre-push: blocks direct pushes to main. All changes to main must go through
# pull requests via /send-it. See CLAUDE.md "Release workflow" for the flow.

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Skip for automated release commits (changesets/action)
LATEST_COMMIT_MSG=$(git log -1 --pretty=%B)
LATEST_COMMITTER=$(git log -1 --pretty=%an)

if echo "$LATEST_COMMIT_MSG" | grep -qE "^release: version packages$"; then
  echo "⏭️  Skipping pre-push check for automated release commit"
  exit 0
fi

if [ "$LATEST_COMMITTER" = "github-actions[bot]" ] || [ "$LATEST_COMMITTER" = "road-runner-bot[bot]" ]; then
  echo "⏭️  Skipping pre-push check for bot commit ($LATEST_COMMITTER)"
  exit 0
fi

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -qE "refs/heads/main$"; then
    echo ""
    echo "${RED}❌ ERROR: Direct pushes to 'main' branch are not allowed${NC}"
    echo ""
    echo "   Use ${YELLOW}/send-it${NC} to push your branch and create a PR:"
    echo ""
    echo "   ${YELLOW}1. Create a feature branch:${NC}"
    echo "      git checkout -b feature/your-feature-name"
    echo ""
    echo "   ${YELLOW}2. Run /send-it${NC} to push, run checks, and create a PR"
    echo ""
    echo "   ${YELLOW}To bypass this hook (NOT RECOMMENDED):${NC}"
    echo "      git push --no-verify"
    echo ""
    exit 1
  fi

  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    exit 0
  fi
done

echo "${GREEN}✅ Pre-push checks passed (main branch protection only)${NC}"
exit 0
